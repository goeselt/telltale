# GitHub personal access token -- needs repo read and workflow read scopes.
# https://github.com/settings/tokens/new?description=telltale-local&scopes=repo,workflow,read:packages
GITHUB_TOKEN=<your-personal-access-token>

# Output path (default: overview.html, use - for stdout)
TELLTALE_OUTPUT=overview.html

# Config directory (default: config/)
TELLTALE_CONFIG_DIR=config/
